{
  "name": "aging-tabs",
  "version": "1.1.0",
  "private": true,
  "description": "Auto-close inactive tabs with visual aging feedback",
  "scripts": {
    "build": "node build.mjs",
    "build:chrome": "node build.mjs --browser=chrome",
    "build:firefox": "node build.mjs --browser=firefox",
    "watch": "node build.mjs --watch",
    "clean": "rm -rf dist",
    "package:chrome": "cd dist/chrome && zip -r ../aging-tabs-chrome.zip .",
    "package:firefox": "cd dist/firefox && zip -r ../aging-tabs-firefox.zip .",
    "package:source": "zip -r dist/aging-tabs-source.zip src/ package.json package-lock.json tsconfig.json build.mjs README.md LICENSE -x 'src/__tests__/*'",
    "test": "vitest run --exclude 'scenarios/**'",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "fast-check": "^4.6.0",
    "playwright": "^1.58.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  }
}
